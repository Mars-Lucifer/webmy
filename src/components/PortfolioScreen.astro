---
const projects = [
  {
    title: "Mochiland",
    description: "B2B-платформа для компании Mochiland, автоматизирующая сделки поставки их товара",
    image: "/image/port_1.webp",
    theme: "light",
    link: "https://mochi-partners.ru",
    status: {
      dotColor: "bg-[rgba(0,222,96,0.60)]",
      text: "В разработке",
    },
  },
  {
    title: "Артур Одилов",
    description: "Сайт-портфолио для профессионального фотографа Москвы",
    image: "/image/port_2.webp",
    theme: "dark",
    link: null,
    status: null,
  },
  {
    title: "Российское Содружество Колледжей",
    description: "Полноценная всероссийская платформа, включает множество функций для развития образовательных учреждений",
    image: "/image/port_3.webp",
    theme: "light",
    link: "https://rosdk.ru",
    status: null,
  },
  {
    title: "Oasis",
    description: "Полный пак для компании по озеленению, включающий фирменный стиль, сайт, AI-бота",
    image: "/image/port_4.webp",
    theme: "light",
    link: "https://www.figma.com/design/ijTXgS45bo4HkBsVnnqRWM/Oasis?node-id=247-2&t=YnCTS9vgX1F6EBJ6-1",
    status: {
      dotColor: "bg-[rgba(255,26,26,0.60)]",
      text: "Сайт временно заморожен",
    },
  },
  {
    title: "EnergyStart",
    description: "Фирменный стиль и сайт компании, занимающейся разработкой систем повышения эффективности ЖКХ",
    image: "/image/port_5.webp",
    theme: "light",
    link: "https://energystart.ru",
    status: null,
  },
];
---

<section id="portfolio" class="w-full flex flex-col gap-[3.75rem] mt-[7.5rem] scroll-mt-[7.5rem]">
  <div class="grid-layout w-full">
    <div
      class="col-span-1 flex justify-between items-center text-[var(--color-black)] text-[1.25rem] font-medium uppercase w-full opacity-0 reveal-trigger"
      data-anim="fade-scale-blur"
    >
      <span>/</span>
      <span data-i18n="portfolio.sectionLabel">портфолио</span>
      <span>/</span>
    </div>
  </div>

  <div class="grid-layout w-full">
    {
      projects.map((project, index) => {
        const cardClasses = `col-span-4 md:col-span-2 group flex flex-col p-[0.25rem] rounded-[2rem] overflow-hidden opacity-0 reveal-trigger transition-transform duration-300 hover:scale-[1.02] ${project.theme === "dark" ? "bg-[#1F2229]" : "bg-white"} ${project.link ? "cursor-pointer" : "cursor-default"}`;

        return project.link ? (
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class={cardClasses}
            data-project-card
            data-project-index={index}
            data-anim={`fade-scale-blur delay-${Math.min((index % 2) * 100 + 100, 300)}`}
          >
            <img
              src={project.image}
              alt={project.title}
              class="w-full aspect-[1.8] object-cover rounded-[1.75rem]"
              loading="lazy"
            />

            <div class="flex flex-col p-[1.5rem] gap-[0.5rem] justify-center items-start h-full">
              <div class="flex flex-col gap-[0.5rem] w-full">
                <div class="flex justify-between items-center gap-[0.75rem] w-full">
                  <h3
                    class={`flex-1 text-[1.5rem] font-medium leading-[1.07] ${project.theme === "dark" ? "text-[#EDEEF0]" : "text-[#1F2229]"}`}
                    data-project-title
                  >
                    {project.title}
                  </h3>

                  <div
                    class={`w-[1.5rem] h-[1.5rem] relative shrink-0 opacity-50 group-hover:opacity-100 transition-opacity duration-300 ${project.theme === "dark" ? "text-[#EDEEF0]" : "text-[#1F2229]"}`}
                  >
                    <svg
                      width="100%"
                      height="100%"
                      viewBox="0 0 24 24"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      class="stroke-current"
                    >
                      <path
                        d="M7 7H17V17"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                      <path
                        d="M7 17L17 7"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </div>
                </div>

                <p class="text-[#828894] text-[1rem] font-normal leading-[1.07] max-w-[24rem]" data-project-description>
                  {project.description}
                </p>
              </div>

              {project.status && (
                <div class="flex items-center gap-[0.5rem] mt-auto pt-[0.25rem]">
                  <div class={`w-[0.5rem] h-[0.5rem] rounded-full ${project.status.dotColor}`} />
                  <span class="text-[rgba(130,136,147,0.60)] text-[1rem] font-normal leading-[1.07]" data-project-status>
                    {project.status.text}
                  </span>
                </div>
              )}
            </div>
          </a>
        ) : (
          <div
            class={cardClasses}
            data-project-card
            data-project-index={index}
            data-anim={`fade-scale-blur delay-${Math.min((index % 2) * 100 + 100, 300)}`}
          >
            <img
              src={project.image}
              alt={project.title}
              class="w-full aspect-[1.8] object-cover rounded-[1.75rem]"
              loading="lazy"
            />

            <div class="flex flex-col p-[1.5rem] gap-[0.5rem] justify-center items-start h-full">
              <div class="flex flex-col gap-[0.5rem] w-full">
                <div class="flex justify-between items-center gap-[0.75rem] w-full">
                  <h3
                    class={`flex-1 text-[1.5rem] font-medium leading-[1.07] ${project.theme === "dark" ? "text-[#EDEEF0]" : "text-[#1F2229]"}`}
                    data-project-title
                  >
                    {project.title}
                  </h3>

                  <div
                    class={`w-[1.5rem] h-[1.5rem] relative shrink-0 opacity-50 group-hover:opacity-100 transition-opacity duration-300 ${project.theme === "dark" ? "text-[#EDEEF0]" : "text-[#1F2229]"}`}
                  >
                    <svg
                      width="100%"
                      height="100%"
                      viewBox="0 0 24 24"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      class="stroke-current"
                    >
                      <path
                        d="M7 7H17V17"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                      <path
                        d="M7 17L17 7"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </div>
                </div>

                <p class="text-[#828894] text-[1rem] font-normal leading-[1.07] max-w-[24rem]" data-project-description>
                  {project.description}
                </p>
              </div>
            </div>
          </div>
        );
      })
    }
  </div>
</section>
